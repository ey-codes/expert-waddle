# Chroma DB persistence directory
CHROMA_PERSIST_DIR=./chroma_db

# Choose embedding backend: local_sentence_transformer | hf | mistral | groq
EMBEDDING_BACKEND=local_sentence_transformer

# Choose LLM backend: local | hf | openai | mistral | groq | gemini
LLM_BACKEND=local

# Gemini / Google Generative Language API key
GEMINI_API_KEY=
GEMINI_MODEL=text-bison-001

# Optional API tokens for other remote endpoints:
HF_API_TOKEN=
OPENAI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
